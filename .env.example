# vRoute Platform — Environment Variables
# Copy to .env and customize. DO NOT commit real secrets.
#
# Environments:
#   local     → make up                          (localhost:8080)
#   staging   → make up-staging                   ($STAGING_DOMAIN, set OIDC_REDIRECT_BASE)
#   prod      → helm install ... values-prod.yaml ($PROD_DOMAIN, pass via --set)

# --- Core ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vkernel
DB_USER=vkernel
DB_PASS=vkernel

JWT_SECRET=vkernel-dev-secret-key-change-in-production-min-32-chars!!
JWT_EXPIRATION=86400000

REDIS_HOST=redis
REDIS_PORT=6379

# --- OIDC SSO (leave empty to disable) ---
OIDC_REDIRECT_BASE=http://localhost:8080
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
